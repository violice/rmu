{
  "name": "@violice/rmu",
  "version": "0.2.8",
  "type": "module",
  "author": "Sergey Ivashko",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "test": "vitest --watch=false",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.69"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "react-native": "dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "size-limit": [
    {
      "path": "dist/index.cjs",
      "limit": "2 KB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "2 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^26.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "size-limit": "^12.0.1",
    "tsdown": "^0.21.8",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
