{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "es2024",
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
  }
}
